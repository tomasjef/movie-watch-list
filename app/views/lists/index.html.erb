<div class="banner banner-default">
  <div class="container">
    <h1>Your Favorite Movies</h1>
    <p>Create and save movies to your watchlist</p>
    <a class="btn btn-primary" href="<%= new_list_path %>">Create a new list</a>
  </div>
</div>

<div class="container mt-4">
  <% if @lists.any? %>
    <div class="row g-3">
      <% @lists.each do |list| %>
        <div class="col-sm-6 col-md-4 col-lg-3">
          <%= link_to list_path(list), class: "text-decoration-none" do %>
            <div class="card h-100 text-white" style="background-image: linear-gradient(rgba(0,0,0,0.3), rgba(0,0,0,0.3)), url('<%= list.image_url %>'); background-size: cover; background-position: center; min-height: 180px;">
              <div class="card-body d-flex align-items-end">
                <h5 class="card-title mb-0"><%= list.name %></h5>
              </div>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="text-center py-5">
      <p class="text-muted fs-5 mb-4">You don't have any lists yet.</p>
      <%= link_to "Create your first list", new_list_path, class: "btn btn-primary btn-lg" %>
    </div>
  <% end %>
</div>
